# Server configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string
# Replace <username>, <password>, and <cluster> with your own Atlas credentials
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ecommerce-kerala?retryWrites=true&w=majority

# JWT Secret — use a long, random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=replace_with_a_long_random_secret_key

# Optional admin account created by the seed script when it does not already exist
ADMIN_NAME=Store Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_admin_password
